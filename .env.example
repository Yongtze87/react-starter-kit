# ============================================
# AI ACCOUNTING ASSISTANT - ENVIRONMENT VARIABLES
# ============================================

# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Your Supabase project URL (find in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (public key for client-side operations)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (secret key for server-side admin operations)
# ⚠️ KEEP THIS SECRET - Never expose to client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# GOOGLE AI (GEMINI) CONFIGURATION
# ============================================

# Google AI API Key for Gemini AI model
# Get your key at: https://ai.google.dev/
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Gemini Model to use (default: gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment: development | production | test
NODE_ENV=development

# Base URL for your application
APP_URL=http://localhost:5173

# Enable mock data for development/testing
# Set to "true" to use mock data, "false" to use real Supabase data
USE_MOCK_DATA=false

# ============================================
# AI CONFIGURATION
# ============================================

# AI Confidence threshold for escalation (0.0 - 1.0)
# Queries below this confidence will be escalated to admin
AI_CONFIDENCE_THRESHOLD=0.8

# Maximum conversation history to maintain (default: 10 messages)
MAX_CONVERSATION_HISTORY=10

# Session timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file size for uploads in MB
MAX_FILE_SIZE_MB=10

# Allowed file types for document uploads
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# RATE LIMITING
# ============================================

# Maximum message length (characters)
MAX_MESSAGE_LENGTH=500

# Rate limit: Maximum requests per minute per user
RATE_LIMIT_PER_MINUTE=20

# ============================================
# VERCEL ANALYTICS (Optional)
# ============================================

# Enable Vercel Analytics
ENABLE_VERCEL_ANALYTICS=false

# ============================================
# DEVELOPMENT/DEBUG
# ============================================

# Enable debug logging
DEBUG=false

# Log level: debug | info | warn | error
LOG_LEVEL=info
